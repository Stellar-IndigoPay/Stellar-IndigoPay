# ─────────────────────────────────────────────────────────────────────────────
# extension/.env.example
#
# The browser extension does NOT use process.env variables at runtime.
# It is compiled by webpack (webpack.config.js) as a fully static bundle
# with no Node.js environment available in the browser context.
#
# Runtime configuration is stored in chrome.storage.sync and is editable
# by the user via the extension's Settings page (settings.html).
# The defaults below document the values that ship in the built extension.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime defaults (stored in chrome.storage.sync) ─────────────────────────
# These are NOT environment variables — they are the hardcoded default values
# in extension/src/settings.ts (DEFAULT_SETTINGS). They are documented here
# for visibility and cross-reference with the rest of the project.
#
# Backend API base URL used by the popup for project / donation API calls.
# The user can override this in the extension Settings page.
# Default: https://api.stellar-indigopay.app
# Local dev: http://localhost:4000
EXTENSION_DEFAULT_BACKEND_URL=https://api.stellar-indigopay.app

# Stellar network to connect to: "testnet" or "mainnet".
# Controls the Horizon endpoint and transaction network passphrase.
# The user can switch networks in the extension Settings page.
# Default: testnet
EXTENSION_DEFAULT_NETWORK=testnet

# Default XLM donation amount pre-filled in the donation form (in XLM).
# The user can change this in the extension Settings page.
# Default: 5
EXTENSION_DEFAULT_DONATION_AMOUNT=5

# ── Build-time (webpack DefinePlugin) ────────────────────────────────────────
# If you add a webpack DefinePlugin block to webpack.config.js, add any
# build-time constants here (e.g. CI environment, release tag).
# No build-time env vars are currently configured.
