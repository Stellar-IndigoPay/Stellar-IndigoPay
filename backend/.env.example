# ─────────────────────────────────────────────────────────────────────────────
# backend/.env.example
#
# Copy this file to .env and fill in the values.
# All variables are optional in development — defaults are shown below.
# Cross-reference: backend/src/config/env.js (Zod schema is the source of truth).
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
# TCP port the Express server listens on.
PORT=4000

# Node environment. Controls logging verbosity and a few feature flags.
# Values: development | production | test
NODE_ENV=development

# ── Stellar ───────────────────────────────────────────────────────────────────
# Stellar network to operate on.
# Values: testnet | mainnet
STELLAR_NETWORK=testnet

# Stellar Horizon REST API endpoint for this network.
# Testnet: https://horizon-testnet.stellar.org
# Mainnet: https://horizon.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org

# Address (C…) of the deployed IndigoPay Soroban contract.
# Required for the on-chain indexer and donation recording.
CONTRACT_ID=

# USDC token contract / issuer address on the selected network.
# Required for the indexer to detect and record USDC payments.
# If unset, USDC indexing is skipped and a warning is logged.
USDC_TOKEN_ADDRESS=

# Conversion rate from USDC to XLM used for CO₂ offset calculations
# and the raised_xlm project counter. Default 8.0 means 1 USDC = 8 XLM.
USDC_TO_XLM_RATE=8.0

# ── Database ──────────────────────────────────────────────────────────────────
# Primary PostgreSQL connection string.
# Format: postgres://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgres://postgres:postgres@localhost:5432/indigopay

# Optional read-replica connection string. Leave blank to route all reads
# to the primary. When set, SELECT queries are load-balanced to the replica.
DATABASE_REPLICA_URL=

# Maximum acceptable replica lag in milliseconds before reads fall back to
# the primary. Default 5000 ms.
MAX_REPLICA_LAG_MS=5000

# PostgreSQL connection pool tuning.
DB_POOL_MAX=20
# Milliseconds before an idle connection is released back to the OS.
DB_POOL_IDLE_TIMEOUT=30000
# Milliseconds to wait for a free connection before throwing ECONNREFUSED.
# Must be < (READINESS_CHECK_TIMEOUT_MS − DB_STATEMENT_TIMEOUT_MS) so
# a slow connection never blocks the /api/readyz probe past its deadline.
DB_POOL_CONNECT_TIMEOUT=1000
# Per-statement timeout pushed to Postgres as SET statement_timeout.
# Prevents slow queries from exhausting the pool. Must be shorter than
# READINESS_CHECK_TIMEOUT_MS (default 4 s).
DB_STATEMENT_TIMEOUT_MS=3000

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection URL used as a caching layer (project list, stats).
# Cache is silently bypassed when Redis is unavailable or this is blank.
# Format: redis://[:password@]<host>:<port>[/<db>]
REDIS_URL=redis://localhost:6379

# ── Authentication ────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens for admin sessions.
# Generate with: openssl rand -hex 32
# Required in production — leave blank only in local dev.
JWT_SECRET=

# Admin panel credentials (used by POST /api/admin/login).
ADMIN_USERNAME=admin
# Bcrypt hash or plaintext password. In production use a bcrypt hash.
ADMIN_PASSWORD=

# Hourly purge of expired refresh tokens and blacklisted access-token jtis.
# Cron syntax; set to "disabled" to turn the job off.
BLACKLIST_CLEANUP_CRON=20 * * * *

# Anthropic Claude API — required for AI project summaries
ANTHROPIC_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS preflight checks.
# Add your frontend origin(s) here.
ALLOWED_ORIGINS=http://localhost:3000

# ── Sentry (observability) ────────────────────────────────────────────────────
# Sentry DSN for server-side error reporting and performance monitoring.
# Get your DSN from https://sentry.io → Project Settings → Client Keys.
# If unset, no events are sent to Sentry.
SENTRY_DSN=

# Fraction of transactions to include in Sentry performance traces.
# 0 disables tracing, 1.0 traces everything. Keep ≤ 0.1 in production
# to avoid high event volume and cost.
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Metrics (Prometheus) ──────────────────────────────────────────────────────
# Set to false to disable the GET /metrics scrape endpoint entirely (404).
METRICS_ENABLED=true

# Bearer token required to access GET /metrics.
# If unset, the endpoint is unauthenticated (local dev only).
# In production set to a long random string: openssl rand -hex 32
METRICS_BEARER_TOKEN=

# ── Rate Limiter ──────────────────────────────────────────────────────────────
# Maximum number of requests per IP per 15-minute window.
RATE_LIMIT_MAX=150

# ── Graceful Shutdown ─────────────────────────────────────────────────────────
# Hard deadline in milliseconds for in-flight request drain on SIGTERM.
# After this the process exits with code 1 regardless of pending requests.
# Keep this lower than your orchestrator's terminationGracePeriodSeconds.
SHUTDOWN_TIMEOUT_MS=30000

# ── Readiness Probe ───────────────────────────────────────────────────────────
# When true, GET /api/readyz returns 503 if Redis is unreachable.
# Default false because Redis is an optional cache, not a hard dependency.
READINESS_REQUIRE_REDIS=false

# Timeout in milliseconds for each readiness subsystem check (DB, Redis, Horizon).
# Must be > (DB_POOL_CONNECT_TIMEOUT + DB_STATEMENT_TIMEOUT_MS) so a slow
# DB never blocks the probe past its own deadline. Default 4000.
READINESS_CHECK_TIMEOUT_MS=4000

# ── Document Storage ──────────────────────────────────────────────────────────
# Backend for storing verification-request supporting documents.
# Values: local | s3 | ipfs
#   local — writes to ./uploads, served at GET /api/uploads/:key (dev default)
#   s3    — requires AWS_* / S3_* variables below
#   ipfs  — requires IPFS_API_URL or WEB3_STORAGE_API_KEY below
STORAGE_BACKEND=local

# Maximum upload size in bytes (default 10 MB).
UPLOAD_MAX_BYTES=10485760

# S3 (only consulted when STORAGE_BACKEND=s3) ─────────────────────────────────
# AWS region where the S3 bucket is located (e.g. us-east-1).
AWS_REGION=
# IAM access key with s3:PutObject / s3:GetObject on the target bucket.
AWS_ACCESS_KEY_ID=
# Corresponding IAM secret access key.
AWS_SECRET_ACCESS_KEY=
# Name of the S3 bucket used for document storage.
S3_BUCKET=
# Optional public base URL for serving objects (e.g. CloudFront distribution).
# If blank, objects are served via the standard S3 URL.
S3_PUBLIC_URL=

# IPFS (only consulted when STORAGE_BACKEND=ipfs) ─────────────────────────────
# web3.storage API token for pinning documents. Takes precedence over IPFS_API_URL.
# Get a token at https://web3.storage
WEB3_STORAGE_API_KEY=

# HTTP API endpoint of an IPFS node (/api/v0/add).
# Works with Infura, Pinata clusters, or a local IPFS daemon.
IPFS_API_URL=

# IPFS gateway base URL used to build publicly accessible document links.
IPFS_GATEWAY_URL=https://w3s.link

# Fall back to local storage when the IPFS upload fails (true | false).
IPFS_FALLBACK_TO_LOCAL=true

# Upload / gateway fetch timeout in milliseconds.
IPFS_TIMEOUT_MS=30000

# ── Turrets (experimental) ────────────────────────────────────────────────────
# Enable Stellar Turrets integration for off-chain contract execution.
# Values: true | false
ENABLE_TURRETS=false

# Port the Turrets service listens on (when ENABLE_TURRETS=true).
TURRETS_PORT=3001
