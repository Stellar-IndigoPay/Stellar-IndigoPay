# ─────────────────────────────────────────────────────────────────────────────
# mobile/.env.example
#
# Copy this file to .env and fill in the values.
# EXPO_PUBLIC_* variables are inlined into the JS bundle at build time by
# Expo's Babel transform. Never put secrets in EXPO_PUBLIC_* variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API ───────────────────────────────────────────────────────────────
# Base URL of the IndigoPay backend API server (no trailing slash).
# Used by all REST calls throughout the app and the error reporter.
# Local dev:   http://localhost:4000
# Production:  https://api.your-domain.com
EXPO_PUBLIC_API_URL=http://localhost:4000

# ── Stellar Network ───────────────────────────────────────────────────────────
# Which Stellar network to connect to: "testnet" or "mainnet".
# Controls the Horizon URL, network passphrase, and asset issuers used
# during transaction building and signing.
EXPO_PUBLIC_STELLAR_NETWORK=testnet

# Stellar Horizon REST API endpoint for this network.
# Testnet: https://horizon-testnet.stellar.org
# Mainnet: https://horizon.stellar.org
EXPO_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban RPC endpoint for smart-contract simulation and submission.
# Testnet: https://soroban-testnet.stellar.org
# Mainnet: https://soroban.stellar.org
EXPO_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ── Smart Contracts ───────────────────────────────────────────────────────────
# Address (C…) of the deployed IndigoPay impact-NFT Soroban contract.
# Required for mint_impact_nft calls. Obtain after running `make deploy`.
EXPO_PUBLIC_CONTRACT_ID=

# ── USDC ──────────────────────────────────────────────────────────────────────
# Stellar account address of the USDC issuer on the selected network.
# Testnet:  GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
# Mainnet:  GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
# Required for USDC donation flows; if unset, USDC option is hidden.
EXPO_PUBLIC_USDC_ISSUER=

# ── Expo Push Notifications ───────────────────────────────────────────────────
# Expo project ID (UUID) used to obtain an Expo push token for notifications.
# Find it in your Expo dashboard (expo.dev) under Project Settings.
# Required for push notification registration; if unset, notifications are
# silently disabled.
EXPO_PUBLIC_PROJECT_ID=

# ── Sentry (observability) ────────────────────────────────────────────────────
# DSN for Sentry React Native error tracking.
# Get your DSN from https://sentry.io → Project Settings → Client Keys.
# If unset, Sentry is silently skipped (errors are still logged to the
# backend via /api/errors/report if EXPO_PUBLIC_API_URL is set).
EXPO_PUBLIC_SENTRY_DSN=
