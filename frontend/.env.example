# ─────────────────────────────────────────────────────────────────────────────
# frontend/.env.example
#
# Copy this file to .env.local and fill in the values.
# NEXT_PUBLIC_* variables are inlined into the browser bundle at build time.
# Never put secrets in NEXT_PUBLIC_* variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API ───────────────────────────────────────────────────────────────
# Base URL of the IndigoPay backend API server (no trailing slash).
# Used by all frontend API calls (axios, fetch, CSRF requests).
# Local dev: http://localhost:4000  Production: https://api.your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:4000

# Public-facing app URL (used to build canonical OG / embed URLs).
# Should match the origin where the Next.js app is deployed.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stellar Network ───────────────────────────────────────────────────────────
# Which Stellar network to connect to: "testnet" or "mainnet".
# Controls the network passphrase used for transaction signing and the
# Horizon / Soroban RPC endpoints shown in the UI.
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Stellar Horizon REST API endpoint.
# Testnet:  https://horizon-testnet.stellar.org
# Mainnet:  https://horizon.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban RPC endpoint used to simulate and submit smart-contract calls.
# Testnet:  https://soroban-testnet.stellar.org
# Mainnet:  https://soroban.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ── Smart Contracts ───────────────────────────────────────────────────────────
# Address (C…) of the deployed IndigoPay impact-NFT contract.
# Required for mint_impact_nft calls. Obtain after running `make deploy`.
# Example: CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC
NEXT_PUBLIC_CONTRACT_ID=

# Address (C…) of the deployed Soroban escrow contract.
# Required for job-escrow flows (create_job / release_escrow).
# Leave blank if the escrow contract is not yet deployed.
NEXT_PUBLIC_ESCROW_CONTRACT_ID=

# ── USDC ──────────────────────────────────────────────────────────────────────
# Stellar account address of the USDC issuer on the selected network.
# Testnet:  GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
# Mainnet:  GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
# Required for USDC donation flows; if unset, USDC option is hidden.
NEXT_PUBLIC_USDC_ISSUER=

# ── Sentry (observability) ────────────────────────────────────────────────────
# Public DSN for Sentry browser error tracking (safe to expose in bundle).
# Get your DSN from https://sentry.io → Project Settings → Client Keys.
# If unset, no events are sent (Sentry is silently disabled).
NEXT_PUBLIC_SENTRY_DSN=

# ── Sentry build-time (CI / production only) ──────────────────────────────────
# These are NOT NEXT_PUBLIC — they are only consumed by the Next.js build
# process (webpack plugin) to upload source maps and create releases.
# They are NOT embedded in the browser bundle.
#
# Organisation slug in Sentry (Settings → Organisation → General)
SENTRY_ORG=
# Project slug in Sentry (Project Settings → General)
SENTRY_PROJECT=
# Auth token with project:releases + org:read scopes
# Generate at https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=
# Short identifier for this build (e.g. git rev-parse --short HEAD).
# Sentry uses it to associate source maps with the correct release.
SENTRY_RELEASE=
